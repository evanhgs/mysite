---
import { content, type Locale } from '@data/content';
import { t } from '@i18n/ui';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const site = content[locale];
---

<section class="head wrap">
	<p class="micro">{locale === 'fr' ? 'Profil' : 'Profile'}</p>
	<h1 class="display">{locale === 'fr' ? 'À propos' : 'About'}</h1>
</section>

<section class="wrap bio">
	{site.about.paragraphs.map((p, i) => (
		<p class:list={['reveal', { lead: i === 0 }]}>{p}</p>
	))}
</section>

<hr class="rule wrap-rule" />

<section class="wrap section cols">
	<div>
		<h2 class="micro">{t(locale, 'about.education')}</h2>
		<p class="degree">{site.about.education.degree}</p>
		<p class="detail">{site.about.education.detail}</p>
	</div>
	<div>
		<h2 class="micro">{t(locale, 'about.skills')}</h2>
		<div class="skills">
			{site.capabilities.map((cap) => (
				<div>
					<h3>{cap.title}</h3>
					<ul>
						{cap.items.map((item) => <li>{item}</li>)}
					</ul>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.head {
		padding-block: clamp(3rem, 7vw, 6rem) clamp(1.5rem, 3vw, 2.5rem);
	}

	.head h1 {
		margin-top: 0.4rem;
	}

	.bio {
		padding-bottom: clamp(2.5rem, 5vw, 4rem);
	}

	.bio p {
		max-width: 58ch;
		margin-bottom: 1.5em;
		font-size: clamp(1.05rem, 1.6vw, 1.35rem);
		font-weight: 300;
		line-height: 1.55;
	}

	.bio .lead {
		max-width: 34ch;
		font-size: var(--h2);
		font-weight: 500;
		line-height: 1.12;
		letter-spacing: -0.02em;
		text-wrap: balance;
	}

	.wrap-rule {
		margin-inline: var(--gutter);
	}

	.cols {
		display: grid;
		gap: 3rem;
	}

	@media (min-width: 900px) {
		.cols {
			grid-template-columns: 1fr 1.6fr;
		}
	}

	.degree {
		margin-top: 1rem;
		font-size: var(--h3);
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: -0.01em;
		line-height: 1.1;
	}

	.detail {
		margin-top: 0.4rem;
		color: var(--muted);
	}

	.skills {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 2rem;
		margin-top: 1rem;
	}

	.skills h3 {
		margin-bottom: 0.9rem;
		font-size: 1.1rem;
		font-weight: 500;
		text-transform: uppercase;
	}

	.skills li {
		padding-block: 0.4rem;
		border-top: 1px solid var(--line);
		font-size: 0.95rem;
	}
</style>
