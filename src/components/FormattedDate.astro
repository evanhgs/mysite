---
import type { Locale } from '@data/content';

interface Props {
	date: Date;
	locale?: Locale;
}

const { date, locale = 'fr' } = Astro.props;
---

<time datetime={date.toISOString()}>
	{
		date.toLocaleDateString(locale === 'fr' ? 'fr-FR' : 'en-US', {
			day: 'numeric',
			month: 'short',
			year: 'numeric',
		})
	}
</time>
