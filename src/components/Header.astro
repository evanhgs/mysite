---
import type { Locale } from '@data/content';
import { otherLocale, routes, t } from '@i18n/ui';

interface Props {
	locale: Locale;
	/** Chemin équivalent dans l'autre langue, pour le switch FR/EN. */
	altPath?: string;
}

const { locale, altPath } = Astro.props;
const r = routes[locale];
const other = otherLocale(locale);
const langHref = altPath ?? routes[other].home;
const path = Astro.url.pathname;
const isActive = (href: string) => path.startsWith(href);
---

<header class="site-header wrap">
	<a class="wordmark" href={r.home}>Evan Hugues<sup>®</sup></a>
	<p class="tag micro">{locale === 'fr' ? 'Développeur' : 'Developer'}<br />full-stack</p>
	<nav aria-label={locale === 'fr' ? 'Navigation principale' : 'Main navigation'}>
		<a class="u-link" href={r.projects} aria-current={isActive(r.projects) ? 'page' : undefined}>{t(locale, 'nav.projects')}</a>
		<a class="u-link" href={r.about} aria-current={isActive(r.about) ? 'page' : undefined}>{t(locale, 'nav.about')}</a>
		<a class="u-link" href={r.blog} aria-current={isActive(r.blog) ? 'page' : undefined}>{t(locale, 'nav.blog')}</a>
		<a class="u-link" href="#contact">{t(locale, 'nav.contact')}</a>
		<a class="lang" href={langHref} aria-label={t(locale, 'lang.switchLabel')}>{t(locale, 'lang.switch')}</a>
	</nav>
</header>

<style>
	.site-header {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1.5rem;
		padding-block: 1.4rem;
	}

	.wordmark {
		font-size: 1rem;
		font-weight: 600;
		letter-spacing: 0.02em;
		text-transform: uppercase;
		white-space: nowrap;
	}

	.wordmark sup {
		font-size: 0.55em;
		font-weight: 500;
	}

	.tag {
		display: none;
		line-height: 1.4;
	}

	@media (min-width: 900px) {
		.tag {
			display: block;
		}
	}

	nav {
		display: flex;
		align-items: baseline;
		gap: clamp(0.9rem, 2.5vw, 2.25rem);
		font-size: 0.78rem;
		font-weight: 500;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	nav a {
		white-space: nowrap;
	}

	nav a[aria-current='page']::after {
		transform: scaleX(1);
	}

	.lang {
		padding: 0.25em 0.7em;
		border: 1px solid var(--ink);
		border-radius: 99px;
		transition: background 0.3s var(--ease), color 0.3s var(--ease);
	}

	.lang:hover,
	.lang:focus-visible {
		background: var(--ink);
		color: var(--paper);
	}

	@media (max-width: 640px) {
		.site-header {
			flex-wrap: wrap;
			row-gap: 0.9rem;
		}
	}
</style>
