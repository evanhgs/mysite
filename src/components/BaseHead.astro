---
import '../styles/global.css';
import type { Locale } from '@data/content';
import { otherLocale } from '@i18n/ui';

interface Props {
	title: string;
	description: string;
	locale: Locale;
	/** Chemin de la même page dans l'autre langue (hreflang). */
	altPath?: string;
}

const { title, description, locale, altPath } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/og.png', Astro.site);
const alt = altPath ? new URL(altPath, Astro.site) : undefined;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />
{alt && <link rel="alternate" hreflang={otherLocale(locale)} href={alt} />}
{alt && <link rel="alternate" hreflang={locale} href={canonicalURL} />}

<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" sizes="32x32" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="alternate" type="application/rss+xml" title="Evan Hugues" href={new URL('rss.xml', Astro.site)} />
<meta name="generator" content={Astro.generator} />
<meta name="theme-color" content="#f1f0ec" />

<link rel="preload" href="/fonts/space-grotesk.woff2" as="font" type="font/woff2" crossorigin />

<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:locale" content={locale === 'fr' ? 'fr_FR' : 'en_US'} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
