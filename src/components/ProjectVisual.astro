---
/**
 * Visuel génératif par projet : composition SVG noir/blanc déterministe,
 * inline dans le HTML — zéro requête réseau, zéro image à charger.
 * Chaque projet a un motif propre, sélectionné par son id.
 */
interface Props {
	id: string;
	title?: string;
}

const { id, title } = Astro.props;

const MOTIFS = [
	'aramis',
	'rmce',
	'dashdust',
	'turbo',
	'valenstagram',
	'hibiki',
	'wipytest',
	'telebox',
] as const;

const MOTIF_BY_ID: Record<string, (typeof MOTIFS)[number]> = {
	'sae5-aramis': 'aramis',
	rmce: 'rmce',
	dashdust: 'dashdust',
	'turbo-selector': 'turbo',
	valenstagram: 'valenstagram',
	hibiki: 'hibiki',
	wipytest: 'wipytest',
	telebox: 'telebox',
};

// Fallback déterministe pour un futur projet sans motif dédié.
const hash = [...id].reduce((a, c) => (a * 31 + c.charCodeAt(0)) >>> 0, 7);
const motif = MOTIF_BY_ID[id] ?? MOTIFS[hash % MOTIFS.length];
---

<svg
	class="visual"
	viewBox="0 0 800 500"
	preserveAspectRatio="xMidYMid slice"
	xmlns="http://www.w3.org/2000/svg"
	role={title ? 'img' : undefined}
	aria-hidden={title ? undefined : 'true'}
>
	{title && <title>{title}</title>}
	<rect width="800" height="500" fill="var(--tile)" />

	{motif === 'aramis' && (
		<g stroke="var(--ink)" fill="none" stroke-width="2">
			{/* Grille isométrique d'entrepôt */}
			{[0, 1, 2, 3, 4].map((i) => (
				<path d={`M${120 + i * 120} 400 l120 -60 l120 60 l-120 60 Z`} />
			))}
			{[0, 1, 2].map((i) => (
				<g>
					<path d={`M${180 + i * 160} 340 l80 -40 l80 40 l-80 40 Z`} fill="var(--paper)" />
					<path d={`M${180 + i * 160} 340 v-70 l80 -40 l80 40 v70 l-80 40 v-70 Z`} fill="var(--paper)" />
					<path d={`M${180 + i * 160} 270 l80 -40 l80 40 l-80 40 Z`} fill="var(--ink)" />
					<path d={`M${260 + i * 160} 310 v70`} />
				</g>
			))}
			<circle cx="640" cy="120" r="52" stroke-dasharray="4 7" />
			<circle cx="640" cy="120" r="8" fill="var(--ink)" />
		</g>
	)}

	{motif === 'rmce' && (
		<g stroke="var(--ink)" fill="none">
			{/* Piste + lignes de vitesse */}
			<ellipse cx="400" cy="250" rx="290" ry="150" stroke-width="3" />
			<ellipse cx="400" cy="250" rx="200" ry="95" stroke-width="2" stroke-dasharray="14 10" />
			{[0, 1, 2, 3, 4, 5].map((i) => (
				<line x1={60} y1={90 + i * 65} x2={190 - i * 12} y2={90 + i * 65} stroke-width="2" />
			))}
			<circle cx="602" cy="180" r="16" fill="var(--ink)" stroke="none" />
			<path d="M602 180 A 202 97 0 0 1 400 345" stroke-width="4" />
		</g>
	)}

	{motif === 'dashdust' && (
		<g fill="var(--ink)">
			{/* Barres de monitoring */}
			{[210, 130, 300, 175, 250, 95, 330, 215, 155, 280].map((h, i) => (
				<rect x={70 + i * 68} y={430 - h} width="38" height={h} />
			))}
			<g stroke="var(--ink)" fill="none" stroke-width="2">
				<path d="M70 160 L 206 220 L 342 130 L 478 190 L 614 90 L 730 140" stroke-dasharray="1 0" />
			</g>
			{[206, 342, 478, 614].map((x, i) => (
				<circle cx={x} cy={[220, 130, 190, 90][i]} r="7" fill="var(--paper)" stroke="var(--ink)" stroke-width="2" />
			))}
		</g>
	)}

	{motif === 'turbo' && (
		<g stroke="var(--ink)" fill="none" stroke-width="2">
			{/* Explosion combinatoire */}
			{Array.from({ length: 24 }, (_, i) => {
				const a = (i / 24) * Math.PI * 2;
				const r1 = 60;
				const r2 = i % 3 === 0 ? 210 : 140;
				return (
					<line
						x1={400 + Math.cos(a) * r1}
						y1={250 + Math.sin(a) * r1}
						x2={400 + Math.cos(a) * r2}
						y2={250 + Math.sin(a) * r2}
					/>
				);
			})}
			<circle cx="400" cy="250" r="60" fill="var(--ink)" />
			<circle cx="400" cy="250" r="235" stroke-dasharray="3 9" />
		</g>
	)}

	{motif === 'valenstagram' && (
		<g stroke="var(--ink)" fill="none" stroke-width="2.5">
			{/* Cadres photo décalés */}
			<rect x="150" y="90" width="240" height="240" />
			<rect x="200" y="140" width="240" height="240" />
			<rect x="250" y="190" width="240" height="240" fill="var(--paper)" />
			<circle cx="370" cy="310" r="62" />
			<circle cx="452" cy="228" r="11" fill="var(--ink)" stroke="none" />
			<path d="M560 120 l90 0 M605 75 l0 90" stroke-width="3" />
		</g>
	)}

	{motif === 'hibiki' && (
		<g fill="var(--ink)">
			{/* Onde sonore */}
			{[30, 70, 120, 190, 260, 190, 300, 240, 160, 90, 200, 260, 140, 80, 40].map((h, i) => (
				<rect x={80 + i * 44} y={250 - h / 2} width="18" height={h} rx="9" />
			))}
		</g>
	)}

	{motif === 'wipytest' && (
		<g stroke="var(--ink)" fill="none" stroke-width="2">
			{/* Radar */}
			{[60, 120, 180, 240].map((r) => (
				<circle cx="400" cy="250" r={r} stroke-dasharray={r > 130 ? '4 8' : undefined} />
			))}
			<line x1="400" y1="250" x2="620" y2="120" stroke-width="3" />
			<path d="M400 250 L620 120 A 258 258 0 0 0 570 80 Z" fill="var(--ink)" opacity="0.14" stroke="none" />
			{[
				[310, 180],
				[480, 330],
				[520, 170],
				[330, 340],
			].map(([x, y]) => (
				<circle cx={x} cy={y} r="7" fill="var(--ink)" stroke="none" />
			))}
		</g>
	)}

	{motif === 'telebox' && (
		<g stroke="var(--ink)" fill="none" stroke-width="2.5">
			{/* Avion en papier + trajectoire */}
			<path d="M170 330 L640 120 L470 380 L390 300 Z" fill="var(--paper)" />
			<path d="M640 120 L390 300 L400 390 L470 380" />
			<path d="M170 330 L640 120" />
			<path d="M110 400 q 60 -90 160 -60" stroke-dasharray="5 8" />
			<path d="M60 300 q 40 -60 110 -50" stroke-dasharray="5 8" />
		</g>
	)}
</svg>

<style>
	.visual {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
</style>
