---
import FormattedDate from '@components/FormattedDate.astro';
import type { Locale } from '@data/content';
import { blogPostUrl, t } from '@i18n/ui';

interface Props {
	locale: Locale;
	posts: {
		slug: string;
		title: string;
		description: string;
		pubDate: Date;
	}[];
}

const { locale, posts } = Astro.props;
---

<section class="head wrap">
	<p class="micro">{t(locale, 'blog.title')} — ({String(posts.length).padStart(2, '0')})</p>
	<h1 class="display">{t(locale, 'blog.title')}</h1>
	<p class="intro">
		{t(locale, 'blog.intro')}
		{locale === 'en' && <span class="micro note">— {t(locale, 'blog.frOnly')}</span>}
	</p>
</section>

<ul class="list">
	{posts.map((post) => (
		<li class="reveal">
			<a class="row wrap" href={blogPostUrl('fr', post.slug)}>
				<span class="micro date"><FormattedDate date={post.pubDate} locale={locale} /></span>
				<span class="title-line">
					<span class="name">{post.title}</span>
					{post.description && <span class="desc">{post.description}</span>}
				</span>
				<span class="micro read">{t(locale, 'blog.read')} ↗</span>
			</a>
		</li>
	))}
</ul>

<style>
	.head {
		padding-block: clamp(3rem, 7vw, 6rem) clamp(2rem, 5vw, 4rem);
	}

	.head h1 {
		margin-block: 0.4rem 1.2rem;
	}

	.intro {
		max-width: 46ch;
		font-size: var(--body-lg);
		font-weight: 300;
		line-height: 1.4;
	}

	.note {
		display: block;
		margin-top: 0.5rem;
	}

	.list {
		border-top: 1px solid var(--line);
	}

	.list li {
		border-bottom: 1px solid var(--line);
	}

	.row {
		display: grid;
		grid-template-columns: 8rem 1fr auto;
		align-items: baseline;
		gap: 1.5rem;
		padding-block: 1.6rem;
		transition: padding-left 0.4s var(--ease);
	}

	.row:hover,
	.row:focus-visible {
		padding-left: calc(var(--gutter) + 0.8rem);
	}

	.name {
		display: block;
		font-size: clamp(1.4rem, 2.8vw, 2.2rem);
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: -0.015em;
		line-height: 1.05;
	}

	.desc {
		display: block;
		margin-top: 0.3rem;
		font-weight: 300;
		color: var(--muted);
	}

	@media (max-width: 700px) {
		.row {
			grid-template-columns: 1fr auto;
		}

		.date {
			display: none;
		}
	}
</style>
