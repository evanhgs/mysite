---
import type { Locale, SiteContent } from '@data/content';
import { routes, t } from '@i18n/ui';

interface Props {
	locale: Locale;
	contact: SiteContent['contact'];
}

const { locale, contact } = Astro.props;
const r = routes[locale];
const year = new Date().getFullYear();
---

<footer id="contact" class="site-footer">
	<div class="wrap cta-block">
		<p class="micro">{t(locale, 'footer.ctaSub')}</p>
		<a class="cta display" href={`mailto:${contact.email}`}>
			{t(locale, 'footer.cta')}
			<span class="arrow" aria-hidden="true">↗</span>
		</a>
		<a class="email u-link" href={`mailto:${contact.email}`}>{contact.email}</a>
	</div>

	<div class="wrap bottom">
		<nav class="cols" aria-label={locale === 'fr' ? 'Liens de pied de page' : 'Footer links'}>
			<div>
				<p class="micro">Menu</p>
				<ul>
					<li><a class="u-link" href={r.projects}>{t(locale, 'nav.projects')}</a></li>
					<li><a class="u-link" href={r.about}>{t(locale, 'nav.about')}</a></li>
					<li><a class="u-link" href={r.blog}>{t(locale, 'nav.blog')}</a></li>
				</ul>
			</div>
			<div>
				<p class="micro">Social</p>
				<ul>
					<li><a class="u-link" href={contact.github} rel="noopener">GitHub</a></li>
					<li><a class="u-link" href={contact.linkedin} rel="noopener">LinkedIn</a></li>
					<li><a class="u-link" href={contact.htb} rel="noopener">Hack The Box</a></li>
				</ul>
			</div>
		</nav>
		<div class="legal">
			<p class="micro">© {year} Evan Hugues — {t(locale, 'footer.rights')}</p>
			<p class="micro">{t(locale, 'footer.madeWith')}</p>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		margin-top: var(--section);
		background: var(--ink);
		color: var(--paper);
	}

	.site-footer .micro {
		color: color-mix(in srgb, var(--paper) 55%, transparent);
	}

	.cta-block {
		padding-block: clamp(4rem, 9vw, 8rem) clamp(2.5rem, 5vw, 4rem);
		border-bottom: 1px solid color-mix(in srgb, var(--paper) 18%, transparent);
	}

	.cta {
		display: block;
		margin-block: 0.5em 0.35em;
	}

	.arrow {
		display: inline-block;
		transition: transform 0.4s var(--ease);
	}

	.cta:hover .arrow,
	.cta:focus-visible .arrow {
		transform: translate(0.08em, -0.08em);
	}

	.email {
		font-size: var(--body-lg);
		font-weight: 300;
	}

	.bottom {
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		gap: 2.5rem;
		padding-block: 2.5rem 2rem;
	}

	.cols {
		display: flex;
		gap: clamp(2.5rem, 8vw, 7rem);
	}

	.cols .micro {
		margin-bottom: 0.9rem;
	}

	.cols li {
		margin-bottom: 0.35rem;
		font-size: 0.95rem;
	}

	.legal {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		justify-content: flex-end;
	}

	::selection {
		background: var(--paper);
		color: var(--ink);
	}
</style>
