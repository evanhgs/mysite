---
import { getCollection } from 'astro:content';
import BlogIndexPage from '@components/BlogIndexPage.astro';
import Site from '@layouts/Site.astro';

const locale = 'fr' as const;

const rawPosts = await getCollection('blog', ({ id }) => id.startsWith('fr/blog/'));
const posts = rawPosts
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.map((p) => ({
		slug: p.id.split('/').pop() ?? p.id,
		title: p.data.title,
		description: p.data.description,
		pubDate: p.data.pubDate,
	}));
---

<Site
	locale={locale}
	title="Journal — Evan Hugues"
	description="Les coulisses de mes projets : décisions techniques, refontes et leçons apprises."
	altPath="/en/blog/"
>
	<BlogIndexPage locale={locale} posts={posts} />
</Site>
