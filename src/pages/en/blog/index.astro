---
import { getCollection } from 'astro:content';
import BlogIndexPage from '@components/BlogIndexPage.astro';
import Site from '@layouts/Site.astro';

const locale = 'en' as const;

// Les articles sont rédigés en français ; l'index EN pointe vers eux.
const rawPosts = await getCollection('blog', ({ id }) => id.startsWith('fr/blog/'));
const posts = rawPosts
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.map((p) => ({
		slug: p.id.split('/').pop() ?? p.id,
		title: p.data.title,
		description: p.data.description,
		pubDate: p.data.pubDate,
	}));
---

<Site
	locale={locale}
	title="Journal — Evan Hugues"
	description="Behind the scenes of my projects: technical decisions, rewrites and lessons learned."
	altPath="/fr/blog/"
>
	<BlogIndexPage locale={locale} posts={posts} />
</Site>
