---
import BaseHead from '@components/BaseHead.astro';
import Footer from '@components/Footer.astro';
import Header from '@components/Header.astro';
import { content, type Locale } from '@data/content';
import Analytics from '@vercel/analytics/astro';

interface Props {
	locale: Locale;
	title: string;
	description: string;
	/** Chemin de la même page dans l'autre langue. */
	altPath?: string;
}

const { locale, title, description, altPath } = Astro.props;
const site = content[locale];
---

<!doctype html>
<html lang={locale}>
	<head>
		<BaseHead title={title} description={description} locale={locale} altPath={altPath} />
	</head>
	<body>
	<Analytics/>
		<Header locale={locale} altPath={altPath} />
		<main>
			<slot />
		</main>
		<Footer locale={locale} contact={site.contact} />
	</body>
</html>
