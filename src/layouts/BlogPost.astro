---
import FormattedDate from '@components/FormattedDate.astro';
import type { CollectionEntry } from 'astro:content';
import Site from '@layouts/Site.astro';
import type { Locale } from '@data/content';
import { routes, t } from '@i18n/ui';

type Props = CollectionEntry<'blog'>['data'] & { locale?: Locale };

const { title, description, pubDate, updatedDate, locale = 'fr' } = Astro.props;
---

<Site locale={locale} title={`${title} — Evan Hugues`} description={description || title}>
	<article class="wrap">
		<header class="post-head">
			<p class="micro">
				<a class="u-link" href={routes[locale].blog}>{t(locale, 'blog.back')}</a>
				 — <FormattedDate date={pubDate} locale={locale} />
			</p>
			<h1 class="post-title">{title}</h1>
			{updatedDate && (
				<p class="micro updated">{t(locale, 'blog.updated')} <FormattedDate date={updatedDate} locale={locale} /></p>
			)}
		</header>
		<div class="prose">
			<slot />
		</div>
	</article>
</Site>

<style>
	.post-head {
		padding-block: clamp(3rem, 7vw, 6rem) clamp(1.5rem, 3vw, 2.5rem);
		border-bottom: 1px solid var(--line);
		margin-bottom: clamp(2rem, 4vw, 3.5rem);
	}

	.post-title {
		max-width: 16ch;
		margin-top: 0.5rem;
		font-size: clamp(2.4rem, 7vw, 6rem);
		font-weight: 500;
		line-height: 0.98;
		letter-spacing: -0.025em;
		text-transform: uppercase;
		text-wrap: balance;
	}

	.updated {
		margin-top: 0.8rem;
	}

	.prose {
		max-width: 68ch;
		padding-bottom: var(--section);
	}

	.prose :global(p) {
		margin-bottom: 1.4em;
		font-size: clamp(1.05rem, 1.5vw, 1.25rem);
		font-weight: 300;
		line-height: 1.65;
	}

	.prose :global(h2),
	.prose :global(h3) {
		margin-block: 1.8em 0.7em;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: -0.01em;
		line-height: 1.1;
	}

	.prose :global(h2) {
		font-size: clamp(1.5rem, 3vw, 2.2rem);
	}

	.prose :global(h3) {
		font-size: clamp(1.2rem, 2vw, 1.6rem);
	}

	.prose :global(a) {
		text-decoration: underline;
		text-underline-offset: 0.15em;
	}

	.prose :global(ul),
	.prose :global(ol) {
		margin-bottom: 1.4em;
		padding-left: 1.2em;
	}

	.prose :global(ul) {
		list-style: '— ';
	}

	.prose :global(ol) {
		list-style: decimal;
	}

	.prose :global(li) {
		margin-bottom: 0.4em;
		font-weight: 300;
	}

	.prose :global(blockquote) {
		margin-block: 1.6em;
		padding-left: 1.2em;
		border-left: 2px solid var(--ink);
		font-size: 1.2em;
		font-weight: 300;
	}

	.prose :global(code) {
		padding: 0.15em 0.4em;
		background: var(--tile);
		font-size: 0.9em;
	}

	.prose :global(pre) {
		margin-bottom: 1.4em;
		padding: 1.2em;
		overflow-x: auto;
		background: var(--ink) !important;
	}

	.prose :global(pre code) {
		padding: 0;
		background: none;
	}

	.prose :global(img) {
		margin-block: 1.6em;
	}

	.prose :global(hr) {
		margin-block: 2em;
		border: none;
		border-top: 1px solid var(--line);
	}
</style>
